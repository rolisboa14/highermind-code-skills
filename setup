#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$(dirname "$SCRIPT_DIR")"

echo ""
echo "  highermind-code-skills"
echo "  ----------------------"
echo ""

for skill in hm-init hm-engineer hm-design hm-qa; do
    target="$SKILLS_DIR/$skill"
    if [ -L "$target" ] || [ -e "$target" ]; then
        rm -rf "$target"
    fi
    ln -s "$SCRIPT_DIR/$skill" "$target"
    echo "  /$skill instalado"
done

echo ""
echo "  Skills de execução instaladas:"
echo ""
echo "    /hm-init       Começar um novo projeto"
echo "    /hm-engineer   Validar código"
echo "    /hm-design     Validar interface"
echo "    /hm-qa         Testar tudo"
echo ""
echo "  Skills de direção (highermind-business-skills):"
echo "    /hm-align      Checar alinhamento de produto"
echo "    /hm-sequoia    Guardrail estratégico: futuro > passado"
echo "    https://github.com/rodrigohighermind/highermind-business-skills"
echo ""

if [ ! -f "$HOME/.claude/CLAUDE.md" ]; then
    echo "  Nota: Nenhum ~/.claude/CLAUDE.md encontrado."
    echo "  Copie o template pra definir seu padrão global:"
    echo ""
    echo "    cp $SCRIPT_DIR/CLAUDE.md.template ~/.claude/CLAUDE.md"
    echo ""
fi

echo "  Pronto."
echo ""
